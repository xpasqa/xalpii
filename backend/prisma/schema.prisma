generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  PARTNER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PartnerStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum ActivityStatus {
  DRAFT
  PENDING_REVIEW
  REVISION_REQUESTED
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum FileVisibility {
  PUBLIC
  PRIVATE
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

enum PaymentProvider {
  DUMMY
  STRIPE
}

enum VoucherStatus {
  ACTIVE
  USED
  CANCELLED
  EXPIRED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum PricingMode {
  SIMPLE
  GROUP_TIER
  TIERED
}

enum ParticipantType {
  ADULT
  CHILD
}

enum AvailabilityMode {
  SCHEDULED_SESSIONS
  ALWAYS_AVAILABLE
}

enum DestinationType {
  COUNTRY
  REGION
  CITY
  AREA
}

enum ActivityRevisionStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  APPLIED
  CANCELLED
}

enum ReviewStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  HIDDEN
}

enum ReviewMediaStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  passwordHash String?    @map("password_hash")
  fullName     String     @map("full_name")
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  partner                   Partner?
  bookings                  Booking[]
  reviews                   Review[]
  approvedReviews           Review[]           @relation("ReviewApprover")
  uploadedFiles             FileAsset[]        @relation("UploadedFiles")
  auditLogEvents            AuditLog[]         @relation("AuditLogActor")
  reviewedActivityRevisions ActivityRevision[] @relation("ActivityRevisionReviewer")

  @@map("users")
}

model Partner {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @unique @map("user_id") @db.Uuid
  businessName String        @map("business_name")
  legalName    String?       @map("legal_name")
  status       PartnerStatus @default(DRAFT)
  phone        String?
  country      String?
  city         String?
  address      String?
  description  String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities        Activity[]
  payouts           Payout[]
  activityRevisions ActivityRevision[]

  @@map("partners")
}

model City {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  country     String
  description String?
  imageFileId String?  @map("image_file_id") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  imageFile  FileAsset? @relation("CityImage", fields: [imageFileId], references: [id], onDelete: SetNull)
  activities Activity[]

  @@map("cities")
}

model Destination {
  id          String          @id @default(uuid()) @db.Uuid
  name        String
  slug        String          @unique
  type        DestinationType
  parentId    String?         @map("parent_id") @db.Uuid
  countryCode String?         @map("country_code")
  description String?
  imageUrl    String?         @map("image_url")
  isActive    Boolean         @default(true) @map("is_active")
  sortOrder   Int             @default(0) @map("sort_order")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  parent     Destination?  @relation("DestinationTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   Destination[] @relation("DestinationTree")
  activities Activity[]

  @@index([parentId, sortOrder])
  @@index([type, isActive])
  @@map("destinations")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  icon        String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  activities Activity[]

  @@map("categories")
}

model Activity {
  id                 String         @id @default(uuid()) @db.Uuid
  partnerId          String         @map("partner_id") @db.Uuid
  cityId             String         @map("city_id") @db.Uuid
  destinationId      String?        @map("destination_id") @db.Uuid
  categoryId         String         @map("category_id") @db.Uuid
  title              String
  slug               String         @unique
  shortDescription   String         @map("short_description")
  description        String
  status             ActivityStatus @default(DRAFT)
  pricingMode        PricingMode    @default(SIMPLE) @map("pricing_mode")
  durationLabel      String?        @map("duration_label")
  meetingPoint       String?        @map("meeting_point")
  cancellationPolicy String?        @map("cancellation_policy")
  importantInfo      String?        @map("important_info")
  included           Json           @default("[]")
  notIncluded        Json           @default("[]") @map("not_included")
  highlights         Json           @default("[]")
  itinerary          Json?
  ratingAverage      Decimal        @default(0) @map("rating_average") @db.Decimal(3, 2)
  reviewCount        Int            @default(0) @map("review_count")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  publishedAt        DateTime?      @map("published_at")

  partner      Partner                @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  city         City                   @relation(fields: [cityId], references: [id], onDelete: Restrict)
  destination  Destination?           @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  category     Category               @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  media        ActivityMedia[]
  pricing      ActivityPricing[]
  pricingTiers ActivityPricingTier[]
  options      ActivityOption[]
  availability ActivityAvailability[]
  bookings     Booking[]
  reviews      Review[]
  revisions    ActivityRevision[]

  @@index([cityId, status])
  @@index([destinationId, status])
  @@index([categoryId, status])
  @@index([partnerId])
  @@map("activities")
}

model ActivityRevision {
  id              String                 @id @default(uuid()) @db.Uuid
  activityId      String                 @map("activity_id") @db.Uuid
  partnerId       String                 @map("partner_id") @db.Uuid
  status          ActivityRevisionStatus @default(DRAFT)
  snapshot        Json
  rejectionReason String?                @map("rejection_reason")
  submittedAt     DateTime?              @map("submitted_at")
  reviewedAt      DateTime?              @map("reviewed_at")
  reviewedById    String?                @map("reviewed_by_id") @db.Uuid
  appliedAt       DateTime?              @map("applied_at")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  partner    Partner  @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  reviewedBy User?    @relation("ActivityRevisionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([activityId, status])
  @@index([partnerId, status])
  @@index([status, submittedAt])
  @@map("activity_revisions")
}

model ActivityMedia {
  id         String   @id @default(uuid()) @db.Uuid
  activityId String   @map("activity_id") @db.Uuid
  fileId     String?  @map("file_id") @db.Uuid
  url        String?
  altText    String?  @map("alt_text")
  sortOrder  Int      @default(0) @map("sort_order")
  isCover    Boolean  @default(false) @map("is_cover")
  createdAt  DateTime @default(now()) @map("created_at")

  activity Activity   @relation(fields: [activityId], references: [id], onDelete: Cascade)
  file     FileAsset? @relation("ActivityMediaFile", fields: [fileId], references: [id], onDelete: SetNull)

  @@index([activityId, sortOrder])
  @@map("activity_media")
}

model ActivityPricing {
  id         String   @id @default(uuid()) @db.Uuid
  activityId String   @map("activity_id") @db.Uuid
  currency   String
  priceCents Int      @map("price_cents")
  priceType  String   @map("price_type")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId, isActive])
  @@map("activity_pricing")
}

model ActivityPricingTier {
  id                   String   @id @default(uuid()) @db.Uuid
  activityId           String   @map("activity_id") @db.Uuid
  currency             String
  minTravelers         Int      @map("min_travelers")
  maxTravelers         Int      @map("max_travelers")
  adultPriceCents      Int      @map("adult_price_cents")
  childPriceCents      Int?     @map("child_price_cents")
  childDiscountPercent Decimal? @default(27) @map("child_discount_percent") @db.Decimal(5, 2)
  priceType            String   @default("per_person") @map("price_type")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId, isActive])
  @@index([activityId, minTravelers, maxTravelers])
  @@map("activity_pricing_tiers")
}

model ActivityOption {
  id               String           @id @default(uuid()) @db.Uuid
  activityId       String           @map("activity_id") @db.Uuid
  title            String
  slug             String
  description      String?
  durationLabel    String?          @map("duration_label")
  meetingPoint     String?          @map("meeting_point")
  meetingTimes     Json?            @map("meeting_times")
  availabilityMode AvailabilityMode @default(SCHEDULED_SESSIONS) @map("availability_mode")
  availableDays    Json?            @map("available_days")
  dailyCapacity    Int?             @map("daily_capacity")
  isDefault        Boolean          @default(false) @map("is_default")
  isActive         Boolean          @default(true) @map("is_active")
  sortOrder        Int              @default(0) @map("sort_order")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  activity        Activity                      @relation(fields: [activityId], references: [id], onDelete: Cascade)
  pricingTiers    ActivityOptionPricingTier[]
  availability    ActivityAvailability[]
  dateInventories ActivityOptionDateInventory[]
  bookings        Booking[]
  reviews         Review[]

  @@unique([activityId, slug])
  @@index([activityId, isActive])
  @@index([activityId, sortOrder])
  @@map("activity_options")
}

model ActivityOptionPricingTier {
  id                   String   @id @default(uuid()) @db.Uuid
  optionId             String   @map("option_id") @db.Uuid
  currency             String   @default("USD")
  minTravelers         Int      @map("min_travelers")
  maxTravelers         Int      @map("max_travelers")
  adultPriceCents      Int      @map("adult_price_cents")
  childPriceCents      Int?     @map("child_price_cents")
  childDiscountPercent Decimal? @default(27) @map("child_discount_percent") @db.Decimal(5, 2)
  priceType            String   @default("per_person") @map("price_type")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  option ActivityOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@index([optionId, isActive])
  @@index([optionId, minTravelers, maxTravelers])
  @@map("activity_option_pricing_tiers")
}

model ActivityOptionDateInventory {
  id          String   @id @default(uuid()) @db.Uuid
  optionId    String   @map("option_id") @db.Uuid
  travelDate  DateTime @map("travel_date")
  capacity    Int?
  bookedCount Int      @default(0) @map("booked_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  option ActivityOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([optionId, travelDate])
  @@index([travelDate])
  @@map("activity_option_date_inventory")
}

model ActivityAvailability {
  id            String    @id @default(uuid()) @db.Uuid
  activityId    String    @map("activity_id") @db.Uuid
  optionId      String?   @map("option_id") @db.Uuid
  startDateTime DateTime  @map("start_date_time")
  endDateTime   DateTime? @map("end_date_time")
  capacity      Int?
  bookedCount   Int       @default(0) @map("booked_count")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  activity Activity        @relation(fields: [activityId], references: [id], onDelete: Cascade)
  option   ActivityOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)
  bookings Booking[]

  @@index([activityId, startDateTime])
  @@index([optionId, startDateTime])
  @@map("activity_availability")
}

model FileAsset {
  id           String         @id @default(uuid()) @db.Uuid
  bucket       String
  objectKey    String         @map("object_key")
  url          String?
  visibility   FileVisibility @default(PRIVATE)
  mimeType     String?        @map("mime_type")
  sizeBytes    Int?           @map("size_bytes")
  originalName String?        @map("original_name")
  uploadedById String?        @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime       @default(now()) @map("created_at")

  uploadedBy    User?           @relation("UploadedFiles", fields: [uploadedById], references: [id], onDelete: SetNull)
  cityImages    City[]          @relation("CityImage")
  activityMedia ActivityMedia[] @relation("ActivityMediaFile")
  reviewMedia   ReviewMedia[]   @relation("ReviewMediaFile")

  @@unique([bucket, objectKey])
  @@index([uploadedById])
  @@map("file_assets")
}

model Booking {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  activityId         String        @map("activity_id") @db.Uuid
  optionId           String?       @map("option_id") @db.Uuid
  availabilityId     String?       @map("availability_id") @db.Uuid
  travelDate         DateTime?     @map("travel_date")
  meetingTime        String?       @map("meeting_time")
  status             BookingStatus @default(PENDING_PAYMENT)
  currency           String
  totalAmountCents   Int           @map("total_amount_cents")
  platformFeeCents   Int           @default(0) @map("platform_fee_cents")
  partnerPayoutCents Int           @default(0) @map("partner_payout_cents")
  bookedAt           DateTime      @default(now()) @map("booked_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  user         User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  activity     Activity              @relation(fields: [activityId], references: [id], onDelete: Restrict)
  option       ActivityOption?       @relation(fields: [optionId], references: [id], onDelete: SetNull)
  availability ActivityAvailability? @relation(fields: [availabilityId], references: [id], onDelete: SetNull)
  participants BookingParticipant[]
  payment      Payment?
  voucher      Voucher?
  review       Review?

  @@index([userId, status])
  @@index([activityId])
  @@index([optionId])
  @@map("bookings")
}

model BookingParticipant {
  id              String          @id @default(uuid()) @db.Uuid
  bookingId       String          @map("booking_id") @db.Uuid
  participantType ParticipantType @default(ADULT) @map("participant_type")
  label           String
  quantity        Int
  priceCents      Int             @map("price_cents")
  createdAt       DateTime        @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_participants")
}

model Payment {
  id                String          @id @default(uuid()) @db.Uuid
  bookingId         String          @unique @map("booking_id") @db.Uuid
  provider          PaymentProvider @default(DUMMY)
  status            PaymentStatus   @default(PENDING)
  amountCents       Int             @map("amount_cents")
  currency          String
  providerReference String?         @map("provider_reference")
  paidAt            DateTime?       @map("paid_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Voucher {
  id        String        @id @default(uuid()) @db.Uuid
  bookingId String        @unique @map("booking_id") @db.Uuid
  code      String        @unique
  qrPayload String        @map("qr_payload")
  status    VoucherStatus @default(ACTIVE)
  usedAt    DateTime?     @map("used_at")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("vouchers")
}

model Review {
  id                 String       @id @default(uuid()) @db.Uuid
  userId             String       @map("user_id") @db.Uuid
  activityId         String       @map("activity_id") @db.Uuid
  bookingId          String       @unique @map("booking_id") @db.Uuid
  optionId           String?      @map("option_id") @db.Uuid
  rating             Int
  title              String?
  comment            String
  status             ReviewStatus @default(PENDING_REVIEW)
  isFeatured         Boolean      @default(false) @map("is_featured")
  adminEditedTitle   String?      @map("admin_edited_title")
  adminEditedComment String?      @map("admin_edited_comment")
  moderationNote     String?      @map("moderation_note")
  submittedAt        DateTime     @default(now()) @map("submitted_at")
  approvedAt         DateTime?    @map("approved_at")
  approvedById       String?      @map("approved_by_id") @db.Uuid
  rejectedAt         DateTime?    @map("rejected_at")
  hiddenAt           DateTime?    @map("hidden_at")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity   Activity        @relation(fields: [activityId], references: [id], onDelete: Cascade)
  booking    Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  option     ActivityOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)
  approvedBy User?           @relation("ReviewApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  media      ReviewMedia[]

  @@index([activityId, status, isFeatured])
  @@index([userId, status])
  @@map("reviews")
}

model ReviewMedia {
  id        String            @id @default(uuid()) @db.Uuid
  reviewId  String            @map("review_id") @db.Uuid
  fileId    String?           @map("file_id") @db.Uuid
  url       String?
  altText   String?           @map("alt_text")
  sortOrder Int               @default(0) @map("sort_order")
  status    ReviewMediaStatus @default(PENDING)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  review Review     @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  file   FileAsset? @relation("ReviewMediaFile", fields: [fileId], references: [id], onDelete: SetNull)

  @@index([reviewId, status, sortOrder])
  @@map("review_media")
}

model Payout {
  id          String       @id @default(uuid()) @db.Uuid
  partnerId   String       @map("partner_id") @db.Uuid
  currency    String
  amountCents Int          @map("amount_cents")
  status      PayoutStatus @default(PENDING)
  reference   String?
  notes       String?
  paidAt      DateTime?    @map("paid_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Restrict)

  @@index([partnerId, status])
  @@map("payouts")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  actorUser User? @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
